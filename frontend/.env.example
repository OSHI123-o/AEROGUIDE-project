#
# Flight lookup (server-side integration)
#
# In production, point this to your backend endpoint that validates
# PNR + last name and returns flight details.
#
# Expected response: JSON array of FlightLookupResult objects.
#
VITE_FLIGHT_LOOKUP_ENDPOINT=/api/flight-lookup

#
# Optional: real weather API key (OpenWeather).
# If omitted, app automatically uses Open-Meteo.
#
VITE_OPENWEATHER_API_KEY=

#
# Google Maps JavaScript API key (required for map markers + dotted route line)
#
VITE_GOOGLE_MAPS_API_KEY=
